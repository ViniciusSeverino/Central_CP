# Copie este arquivo para .env (ou .env.local) e preencha com as chaves
# do seu projeto Supabase. NUNCA commite o .env de verdade.

# Painel do Supabase → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=

# Somente se o backend (ex: funções serverless na Vercel) precisar de
# acesso privilegiado. NUNCA exponha esta chave no frontend.
SUPABASE_SERVICE_ROLE_KEY=
