# Credenciais do projeto Supabase usado pelo Central CP.
# A anon/publishable key é segura para uso client-side (é o que o app usa no navegador).
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Nota: prototype/central-cp.html é um HTML estático sem etapa de build, então
# hoje ele NÃO lê este .env — SUPABASE_URL e SUPABASE_ANON_KEY estão embutidos
# diretamente nas constantes do topo do <script>. Este arquivo serve de
# referência e para uma futura versão em src/ que use um bundler real.
